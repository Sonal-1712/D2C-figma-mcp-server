{
  "name": "design-2-code-v1",
  "version": "0.1.0",
  "private": true,
  "description": "A library of React components based on designs from Figma",
  "scripts": {
    "build": "pnpm --filter \"*\" run build",
    "dev": "pnpm --filter \"*\" run dev",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "pnpm --filter \"*\" run test",
    "storybook": "pnpm --filter storybook-v1 run storybook",
    "publish:storybook:v1": "pnpm --filter storybook-v1 run build-storybook && gh-pages -d applications/storybook-v1/storybook-static --dotfiles"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^4.0.0",
    "gh-pages": "^6.3.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@10.0.0+sha512.b8fef5494bd3fe4cbd4edabd0745df2ee5be3e4b0b8b08fa643aa3e4c6702ccc0f00d68fa8a8c9858a735a0032485a44990ed2810526c875e416f001b17df12b",
  "dependencies": {
    "classnames": "^2.5.1"
  }
}
